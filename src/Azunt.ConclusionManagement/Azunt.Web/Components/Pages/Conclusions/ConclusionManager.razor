@page "/Conclusions"
@page "/Conclusions/Manage"

@namespace Azunt.Web.Pages.Conclusions
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.FluentUI.AspNetCore.Components
@rendermode InteractiveServer

<h3 class="mt-1 mb-1 d-flex justify-content-between align-items-center">
    <span class="d-flex align-items-center">
        Conclusions
        <button type="button" class="btn btn-sm btn-primary ms-2" @onclick="ShowEditorForm">Add New</button>
    </span>

    <span class="d-flex align-items-center">
        <FluentButton IconEnd="@(new Icons.Regular.Size16.Table())"
                      Appearance="Appearance.Accent"
                      OnClick="ExportExcel"
                      Class="align-middle"
                      Style="height: 32px; padding-top: 4px;">
            Excel Export
        </FluentButton>
    </span>
</h3>

<div class="row">
    <div class="col-md-12">
        @if (models == null)
        {
            <p>Loading...</p>
        }
        else
        {
            <div class="table-responsive" style="min-height: 400px;">
                <table class="table table-bordered table-hover align-middle">
                    <thead class="thead-light">
                        <tr>
                            <th class="text-center text-nowrap" @onclick="@(() => SortBy(nameof(Azunt.ConclusionManagement.Conclusion.Name)))" style="cursor: pointer; width: 220px;">
                                Name <Azunt.Components.Sorting.SortOrderArrow SortColumn="Name" SortOrder="@sortOrder" />
                            </th>
                            <th class="text-center" @onclick="@(() => SortBy(nameof(Azunt.ConclusionManagement.Conclusion.Content)))" style="cursor: pointer;">
                                Content <Azunt.Components.Sorting.SortOrderArrow SortColumn="Content" SortOrder="@sortOrder" />
                            </th>
                            <th class="text-center text-nowrap" @onclick="@(() => SortBy(nameof(Azunt.ConclusionManagement.Conclusion.CreatedAt)))" style="cursor: pointer; width: 180px;">
                                Created <Azunt.Components.Sorting.SortOrderArrow SortColumn="CreatedAt" SortOrder="@sortOrder" />
                            </th>
                            <th class="text-center text-nowrap" style="width: 100px;">Active</th>
                            <th class="text-center text-nowrap" style="width: 180px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (models.Count == 0)
                        {
                            <tr>
                                <td colspan="5" class="text-center">No data.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var m in models)
                            {
                                <tr>
                                    <td class="text-nowrap">
                                        <strong>@m.Name</strong>
                                    </td>
                                    <td>
                                        @if (string.IsNullOrWhiteSpace(m.Content))
                                        {
                                            <span class="text-muted">No content</span>
                                        }
                                        else
                                        {
                                            <span>@m.Content</span>
                                        }
                                    </td>
                                    <td class="text-center text-nowrap small">@ShowTimeOrDate(m.CreatedAt)</td>
                                    <td class="text-center">
                                        <input type="checkbox" checked="@(m.Active == true)" disabled />
                                    </td>
                                    <td class="text-center text-nowrap">
                                        <button class="btn btn-sm btn-primary" @onclick="() => EditBy(m)">Edit</button>
                                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteBy(m)">Del</button>
                                        <button class="btn btn-sm btn-warning" @onclick="() => ToggleBy(m)">Active</button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="col-md-12">
        <Azunt.Components.Paging.Pager Model="pager" PageIndexChanged="PageIndexChanged" />
    </div>

    <div class="col-md-12">
        <Azunt.Components.Search.SearchBox placeholder="Search Conclusions..." SearchQueryChanged="Search" />
    </div>
</div>

<Azunt.Web.Components.Pages.Conclusions.Components.ModalForm @ref="EditorFormReference"
                                                         ModelSender="model"
                                                         CreateCallback="CreateOrEdit"
                                                         EditCallback="CreateOrEdit"
                                                         UserName="@UserName">
    <EditorFormTitle>@EditorFormTitle</EditorFormTitle>
</Azunt.Web.Components.Pages.Conclusions.Components.ModalForm>

@if (IsDeleteDialogShow)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog" style="background-color: rgba(0, 0, 0, 0.5);">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content shadow">
                <div class="modal-header">
                    <h5 class="modal-title">Delete Conclusion</h5>
                    <button type="button" class="btn-close" aria-label="Close" @onclick="DeleteClose"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete <strong>@model.Name</strong>?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-danger" @onclick="DeleteClick">Yes, Delete</button>
                    <button type="button" class="btn btn-secondary" @onclick="DeleteClose">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

@if (IsInlineDialogShow)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog" style="background-color: rgba(0, 0, 0, 0.5);">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content shadow">
                <div class="modal-header">
                    <h5 class="modal-title">Change Active State</h5>
                    <button type="button" class="btn-close" aria-label="Close" @onclick="ToggleClose"></button>
                </div>
                <div class="modal-body">
                    <p>Do you want to change the Active state of <strong>@model.Name</strong>?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary" @onclick="ToggleClick">Yes, Change</button>
                    <button type="button" class="btn btn-secondary" @onclick="ToggleClose">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}
